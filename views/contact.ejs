<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact — BrandForge</title>
  <meta name="description" content="Start your next project with BrandForge. Fill out a brief and we'll respond within 24 hours." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="icon" href="/logo.png" type="image/x-icon">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>
  <div class="noise-overlay"></div>

  <nav id="nav">
    <a href="/" class="nav-logo">BrandForge</a>
    <div class="nav-links">
      <a href="/services">Services</a>
      <a href="/work">Work</a>
      <a href="/contact" class="nav-cta">Start a Project</a>
    </div>
    <button class="nav-burger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </nav>
  <div class="mobile-nav">
    <a href="/">Home</a>
    <a href="/services">Services</a>
    <a href="/work">Work</a>
    <a href="/contact">Contact</a>
  </div>

  <div class="contact-wrapper">
    <!-- LEFT — dark -->
    <div class="contact-left">
      <canvas id="contact-canvas"></canvas>
      <p class="section-label reveal">Let's Talk</p>
      <h1 class="section-title reveal" style="font-size:clamp(40px,6vw,72px)">
        Start something great.
      </h1>

      <div class="contact-info reveal">
        <div class="contact-info-item">
          <div class="contact-info-label">Email</div>
          <div class="contact-info-val">brandforge851@gmail.com</div>
        </div>
        <div class="contact-info-item">
          <div class="contact-info-label">Response Time</div>
          <div class="contact-info-val">Within 24 hours</div>
        </div>
        <div class="contact-info-item">
          <div class="contact-info-label">Location</div>
          <div class="contact-info-val">Remote — Worldwide</div>
        </div>
      </div>

      
    </div>

    <!-- RIGHT — light -->
    <div class="contact-right">
      <p class="section-label reveal">Project Brief</p>
      <form class="contact-form reveal" method="post" action="/form">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" placeholder="Your name" name="name" required />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" placeholder="your@email.com" name="email" required />
          </div>
        </div>
        <div class="form-group">
          <label for="company">Company / Website</label>
          <input name="company" type="text" id="company" placeholder="Your company or URL" />
        </div>
        <div class="form-group">
          <label for="service">Service Needed</label>
          <select id="service" name="service" required>
            <option value="" disabled selected>Select a service...</option>
            <option value="web">Web Design &amp; Development</option>
            <option value="ecommerce">E-Commerce</option>
            <option value="seo">SEO</option>
            <option value="ads">Paid Advertising</option>
            <option value="brand">Brand Identity</option>
            <option value="social">Social Media Management</option>
            <option value="full">Full Digital Package</option>
          </select>
        </div>
        <div class="form-group">
          <label for="budget">Budget Range</label>
          <select id="budget" name="budget" required>
            <option value="" disabled selected>Select your budget...</option>
            <option value="500">Under $500/mo</option>
            <option value="1000">$500 – $1,000/mo</option>
            <option value="2500">$1,000 – $2,500/mo</option>
            <option value="5000">$2,500 – $5,000/mo</option>
            <option value="10000">$5,000+/mo</option>
          </select>
        </div>
        <div class="form-group">
          <label for="message">Tell us about your project</label>
          <textarea name="message" id="message" rows="4" placeholder="Goals, timeline, details..." required></textarea>
        </div>
        <button type="submit" class="form-submit" id="submit-btn">Send Brief →</button>
        <div id="success-msg" style="display:none;padding:12px;background:rgba(0,113,227,0.08);border-radius:8px;font-size:14px;color:var(--blue);text-align:center">
          ✓ Message received — we'll be in touch within 24 hours.
        </div>
      </form>
    </div>
  </div>

  <footer>
    <div class="footer-top">
      <div class="footer-mark">BrandForge</div>
      <div class="footer-tagline">We build what others only imagine.</div>
    </div>
    <div class="footer-bottom">
      <span class="footer-copy">© 2025 BrandForge Studio. All rights reserved.</span>
      <div class="footer-links">
        <a href="/services">Services</a>
        <a href="/work">Work</a>
        <a href="/contact">Contact</a>
      </div>
    </div>
  </footer>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>