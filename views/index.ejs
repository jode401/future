  <!-- STICKY MOBILE CTA -->
  <div class="sticky-cta" id="sticky-cta">
    <a href="/contact">Get a Free Consultation</a>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="/js/main.js"></script>
  <script>
    // Hide sticky CTA when hero is visible
    const heroCta = document.querySelector('.hero-actions');
    const stickyCta = document.getElementById('sticky-cta');
    if (heroCta && stickyCta) {
      const heroObs = new IntersectionObserver(entries => {
        stickyCta.style.opacity = entries[0].isIntersecting ? '0' : '1';
        stickyCta.style.pointerEvents = entries[0].isIntersecting ? 'none' : 'all';
      }, { threshold: 0.5 });
      heroObs.observe(heroCta);
      stickyCta.style.transition = 'opacity 0.3s';
    }
  </script>
</body>
</html>