      <div class="hero-trust">
        <div class="trust-item"><div class="trust-dot"></div>3+ Projects Delivered</div>
        <div class="trust-item"><div class="trust-dot"></div>100% Client Satisfaction</div>
        <div class="trust-item"><div class="trust-dot"></div>Remote — Worldwide</div>
