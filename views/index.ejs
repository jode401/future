<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BrandForge — Digital Agency</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:ital,wght@0,300;0,400;1,300&family=Playfair+Display:ital@1&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css" />
    <link rel="icon" href="/logo.png" type="image/x-icon">
</head>
<body>

  <nav id="nav">
    <a href="/" class="nav-logo">BrandForge</a>
    <div class="nav-links">
      <a href="/services">Services</a>
      <a href="/work">Work</a>
      <a href="/contact" class="nav-cta">Start a Project</a>
    </div>
  </nav>

  <!-- HERO -->
  <section id="hero">
    <canvas id="hero-canvas"></canvas>
    <div class="hero-content">
      <p class="hero-eyebrow">Digital Agency · Est. 2025</p>
      <h1 class="hero-title">
        WE BUILD
        <em>the future</em>
        ONLINE.
      </h1>
      <p class="hero-sub">Websites that convert. Marketing that moves. Results that matter.</p>
      <div class="hero-actions">
        <a href="/contact" class="btn-primary">Start Your Project</a>
        <a href="/work" class="btn-outline">View Our Work</a>
      </div>
    </div>
    <div class="hero-scroll">
      <div class="hero-scroll-line"></div>
      <span>Scroll</span>
    </div>
  </section>

  <!-- TICKER -->
  <div class="ticker-wrap">
    <div class="ticker-inner">
      <span class="ticker-item"><span>Web Design</span></span>
      <span class="ticker-item">·</span>
      <span class="ticker-item"><span>Branding</span></span>
      <span class="ticker-item">·</span>
      <span class="ticker-item"><span>SEO</span></span>
      <span class="ticker-item">·</span>
      <span class="ticker-item"><span>Paid Ads</span></span>
      <span class="ticker-item">·</span>
      <span class="ticker-item"><span>E-Commerce</span></span>
      <span class="ticker-item">·</span>
      <span class="ticker-item"><span>Social Media</span></span>
      <span class="ticker-item">·</span>
      <span class="ticker-item"><span>Web Design</span></span>
      <span class="ticker-item">·</span>
      <span class="ticker-item"><span>Branding</span></span>
      <span class="ticker-item">·</span>
      <span class="ticker-item"><span>SEO</span></span>
      <span class="ticker-item">·</span>
      <span class="ticker-item"><span>Paid Ads</span></span>
      <span class="ticker-item">·</span>
      <span class="ticker-item"><span>E-Commerce</span></span>
      <span class="ticker-item">·</span>
      <span class="ticker-item"><span>Social Media</span></span>
      <span class="ticker-item">·</span>
    </div>
  </div>

  <!-- ABOUT -->
  <section>
    <div id="about">
      <div class="about-left reveal">
        <div class="big-number">10+</div>
      </div>
      <div class="about-right reveal">
        <p class="section-label">Who We Are</p>
        <h2 class="section-title">
          A studio obsessed<br>with <em>results</em>.
        </h2>
        <p class="about-body">
          BrandForge is a full-service digital agency specializing in website creation and digital marketing.
          We design, build, and grow brands online — combining sharp aesthetics with data-driven strategy
          to deliver measurable impact for every client we work with.
        </p>
        <div class="about-stats">
          <div class="stat-item">
            <div class="stat-num">120+</div>
            <div class="stat-label">Projects Done</div>
          </div>
          <div class="stat-item">
            <div class="stat-num">98%</div>
            <div class="stat-label">Client Satisfaction</div>
          </div>
          <div class="stat-item">
            <div class="stat-num">3×</div>
            <div class="stat-label">Avg. ROI Boost</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services-home">
    <div class="services-header reveal">
      <div>
        <p class="section-label" style="color:#666">What We Do</p>
        <h2 class="section-title">Our <em>Core</em><br>Services</h2>
      </div>
      <a href="/services" class="btn-outline" style="color:#000;border-color:#000">See All Services</a>
    </div>
    <div class="services-grid">
      <div class="service-card reveal">
        <div class="service-num">01</div>
        <div class="service-name">Web Design &amp; Dev</div>
        <p class="service-desc">Custom websites built from scratch — fast, responsive, and designed to convert visitors into customers. From landing pages to complex platforms.</p>
      </div>
      <div class="service-card reveal">
        <div class="service-num">02</div>
        <div class="service-name">Digital Marketing</div>
        <p class="service-desc">SEO, paid ads, email campaigns, and social media management — unified under one strategy, driven by real data and relentless optimization.</p>
      </div>
      <div class="service-card reveal">
        <div class="service-num">03</div>
        <div class="service-name">Brand Identity</div>
        <p class="service-desc">Logo design, brand systems, visual language — we craft identities that are recognizable, consistent, and built to last in competitive markets.</p>
      </div>
    </div>
  </section>

  <!-- WORK PREVIEW -->
  <section style="padding:120px 48px">
    <div id="work-home">
      <div class="work-header reveal">
        <div>
          <p class="section-label">Recent Work</p>
          <h2 class="section-title">Selected<br><em>Projects</em></h2>
        </div>
        <a href="/work" class="btn-outline">View All Work</a>
      </div>
      <div class="work-grid">
        <div class="work-item reveal">
          <canvas class="work-item-canvas"></canvas>
          <div class="work-overlay">
            <div class="work-tag">E-Commerce · Shopify</div>
            <div class="work-title">LuxeHome Store</div>
          </div>
        </div>
        <div class="work-item reveal">
          <canvas class="work-item-canvas"></canvas>
          <div class="work-overlay">
            <div class="work-tag">Marketing · Meta Ads</div>
            <div class="work-title">FitLife Campaign</div>
          </div>
        </div>
        <div class="work-item reveal">
          <canvas class="work-item-canvas"></canvas>
          <div class="work-overlay">
            <div class="work-tag">Web Design · React</div>
            <div class="work-title">Apex SaaS Platform</div>
          </div>
        </div>
        <div class="work-item reveal">
          <canvas class="work-item-canvas"></canvas>
          <div class="work-overlay">
            <div class="work-tag">Branding · Full Identity</div>
            <div class="work-title">Noir Coffee Co.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section id="process">
    <div class="process-inner">
      <div class="reveal">
        <p class="section-label" style="color:#666">How We Work</p>
        <h2 class="section-title" style="color:#000">Our <em>Process</em></h2>
      </div>
      <div class="process-steps">
        <div class="process-step reveal">
          <div class="step-num">01</div>
          <div class="step-title">Discover</div>
          <p class="step-desc">We start with a deep dive into your business, goals, competitors, and audience. No assumptions — just clarity.</p>
        </div>
        <div class="process-step reveal">
          <div class="step-num">02</div>
          <div class="step-title">Strategize</div>
          <p class="step-desc">We build a custom roadmap: design direction, marketing channels, timelines, and KPIs that actually matter to you.</p>
        </div>
        <div class="process-step reveal">
          <div class="step-num">03</div>
          <div class="step-title">Execute</div>
          <p class="step-desc">Our team designs, develops, and launches — with complete transparency and weekly updates throughout.</p>
        </div>
        <div class="process-step reveal">
          <div class="step-num">04</div>
          <div class="step-title">Grow</div>
          <p class="step-desc">Post-launch, we analyze, optimize, and scale. Your success is our success — it's that simple.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="cta">
    <canvas id="cta-canvas"></canvas>
    <div class="cta-content">
      <h2 class="cta-title reveal">
        READY TO
        <em>grow?</em>
      </h2>
      <a href="/contact" class="btn-primary reveal">Let's Build Together</a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="footer-top">
      <div class="footer-mark">BrandForge</div>
      <div class="footer-tagline">We build what others only imagine.</div>
    </div>
    <div class="footer-bottom">
      <span class="footer-copy">© 2025 BrandForge Studio. All rights reserved.</span>
      <div class="footer-links">
        <a href="/services">Services</a>
        <a href="/work">Work</a>
        <a href="/contact">Contact</a>
      </div>
    </div>
  </footer>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>