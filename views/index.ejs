<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    /* ===== CTA ENHANCEMENTS ===== */
    .cta-note {
      display: block;
      margin-top: 14px;
      font-size: 12px;
      color: rgba(255,255,255,0.35);
      letter-spacing: -0.12px;
    }
    .hero-trust {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 20px;
      margin-top: 28px;
      padding-top: 28px;
      border-top: 1px solid rgba(255,255,255,0.07);
      opacity: 0;
      animation: fadeUp 0.8s 1.1s forwards;
    }
    .trust-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: rgba(255,255,255,0.35);
      letter-spacing: -0.1px;
    }
    .trust-dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: #0071e3;
      flex-shrink: 0;
    }
    /* Mid-page inline CTA */
    .inline-cta {
      background: #f5f5f7;
      color: #1d1d1f;
      padding: 80px 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 40px;
      flex-wrap: wrap;
    }
    .inline-cta-left h2 {
      font-size: clamp(28px,4vw,40px);
      font-weight: 600;
      line-height: 1.1;
      letter-spacing: -0.28px;
      color: #1d1d1f;
      max-width: 480px;
    }
    .inline-cta-left p {
      font-size: 14px;
      color: rgba(0,0,0,0.5);
      letter-spacing: -0.224px;
      margin-top: 8px;
    }
    .inline-cta-right {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 8px;
      flex-shrink: 0;
    }
    .inline-cta-right .btn-primary { background: #0071e3; color: #fff; min-height: 48px; display: flex; align-items: center; padding: 0 28px; }
    .inline-cta-right .btn-primary:hover { background: #0077ed; }
    .inline-cta-note { font-size: 11px; color: rgba(0,0,0,0.35); }
    /* Sticky bottom CTA — mobile */
    .sticky-cta {
      display: none;
      position: fixed;
      bottom: 0; left: 0; right: 0;
      z-index: 150;
      background: rgba(0,0,0,0.95);
      backdrop-filter: blur(16px);
      padding: 14px 20px;
      border-top: 1px solid rgba(255,255,255,0.08);
    }
    .sticky-cta a {
      display: block;
      background: #0071e3;
      color: #fff;
      text-align: center;
      font-size: 15px;
      font-weight: 500;
      padding: 14px;
      border-radius: 12px;
      letter-spacing: -0.2px;
    }
    @media (max-width:900px) {
      .sticky-cta { display: block; }
      .inline-cta { padding: 60px 20px; flex-direction: column; }
      .inline-cta-right { align-items: stretch; width: 100%; }
      .inline-cta-right .btn-primary { justify-content: center; }
      .inline-cta-note { text-align: center; }
      body { padding-bottom: 76px; }
    }
  </style>
  <title>BrandForge — Digital Agency</title>
  <meta name="description" content="BrandForge is a full-service digital agency. We design, build, and grow brands online." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css" />
  <link rel="icon" href="/logo.png" type="image/x-icon">
</head>
<body>
