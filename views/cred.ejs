<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login Error</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: Arial, Helvetica, sans-serif;
      background: linear-gradient(135deg, #fff1f2, #f8fafc);
      padding: 20px;
      color: #111827;
    }

    .card {
      width: 100%;
      max-width: 420px;
      background: #ffffff;
      border-radius: 20px;
      padding: 32px;
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.08);
      border: 1px solid #fecaca;
      text-align: center;
    }

    .icon {
      width: 64px;
      height: 64px;
      margin: 0 auto 16px;
      border-radius: 50%;
      background: #fee2e2;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 30px;
    }

    h1 {
      font-size: 26px;
      margin-bottom: 10px;
      color: #b91c1c;
    }

    p {
      color: #6b7280;
      font-size: 15px;
      line-height: 1.6;
    }

    .button {
      display: inline-block;
      margin-top: 22px;
      padding: 12px 18px;
      border-radius: 12px;
      background: #111827;
      color: #fff;
      text-decoration: none;
      font-weight: 600;
    }

    .button:hover {
      background: #1f2937;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="icon">!</div>
    <h1>Login Failed</h1>
    <p>The name or password does not match.</p>
    <a class="button" href="/login">Try Again</a>
  </div>
</body>
</html>