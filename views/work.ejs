<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Our Work — BrandForge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:ital,wght@0,300;0,400;1,300&family=Playfair+Display:ital@1&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css" />
  <style>
    /* ===== WORK PAGE SPECIFIC ===== */
    .projects-section {
      padding: 80px 48px 120px;
      max-width: 1400px;
      margin: 0 auto;
    }

    /* Featured projects — large cards stacked */
    .project-card {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      border: 1px solid #1a3d2e;
      margin-bottom: 2px;
      overflow: hidden;
      position: relative;
      transition: border-color 0.4s;
    }
    .project-card:hover { border-color: var(--gold); }
    .project-card.reverse { direction: rtl; }
    .project-card.reverse > * { direction: ltr; }

    /* Browser mockup preview */
    .project-preview {
      position: relative;
      background: #080f0b;
      overflow: hidden;
      min-height: 420px;
    }
    .browser-chrome {
      position: absolute;
      top: 0; left: 0; right: 0;
      z-index: 2;
      background: #0d2b1f;
      border-bottom: 1px solid #1a3d2e;
      padding: 10px 14px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .browser-dots { display: flex; gap: 5px; }
    .browser-dot {
      width: 8px; height: 8px; border-radius: 50%;
    }
    .dot-r { background: #3a1a1a; }
    .dot-y { background: #3a2e10; }
    .dot-g { background: #1a3d2e; }
    .browser-bar {
      flex: 1;
      background: #0a1f14;
      border: 1px solid #1a3d2e;
      border-radius: 2px;
      padding: 4px 10px;
      font-family: var(--font-body);
      font-size: 9px;
      letter-spacing: 1px;
      color: #4a6555;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .browser-visit {
      font-size: 9px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--gold-dk);
      white-space: nowrap;
      text-decoration: none;
      transition: color 0.2s;
    }
    .browser-visit:hover { color: var(--gold); }

    /* iframe preview */
    .preview-iframe-wrap {
      position: absolute;
      top: 36px; left: 0; right: 0; bottom: 0;
      overflow: hidden;
    }
    .preview-iframe-wrap iframe {
      width: 200%;
      height: 200%;
      transform: scale(0.5);
      transform-origin: top left;
      border: none;
      pointer-events: none;
    }
    /* Overlay to block iframe interactions but allow card hover */
    .preview-overlay {
      position: absolute;
      top: 36px; left: 0; right: 0; bottom: 0;
      z-index: 3;
      background: transparent;
    }
    /* Shimmer while loading */
    .preview-shimmer {
      position: absolute;
      inset: 36px 0 0;
      background: #0a1f14;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1;
      transition: opacity 0.6s;
    }
    .shimmer-icon {
      font-family: var(--font-display);
      font-size: 48px;
      color: #1a3d2e;
      letter-spacing: 4px;
    }

    /* Project info panel */
    .project-info {
      background: #080f0b;
      padding: 52px 48px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      border-left: 1px solid #1a3d2e;
    }
    .project-card.reverse .project-info {
      border-left: none;
      border-right: 1px solid #1a3d2e;
    }
    .project-num {
      font-family: var(--font-display);
      font-size: 80px;
      color: #1a3d2e;
      line-height: 1;
      margin-bottom: 16px;
      user-select: none;
    }
    .project-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-bottom: 20px;
    }
    .project-tag {
      font-size: 9px;
      letter-spacing: 3px;
      text-transform: uppercase;
      border: 1px solid #1a3d2e;
      color: var(--gold-dk);
      padding: 4px 10px;
    }
    .project-name {
      font-family: var(--font-display);
      font-size: clamp(28px, 4vw, 48px);
      letter-spacing: 1px;
      line-height: 1;
      color: var(--white);
      margin-bottom: 8px;
    }
    .project-client {
      font-size: 11px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 24px;
    }
    .project-desc {
      font-size: 13px;
      color: #4a6555;
      line-height: 1.9;
      margin-bottom: 32px;
      max-width: 380px;
    }
    .project-meta {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      padding-top: 24px;
      border-top: 1px solid #1a3d2e;
      margin-bottom: 32px;
    }
    .meta-label {
      font-size: 9px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #245c42;
      margin-bottom: 4px;
    }
    .meta-val {
      font-size: 12px;
      color: var(--white);
      letter-spacing: .5px;
    }
    .project-links {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }
    .link-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--gold);
      color: var(--forest);
      font-family: var(--font-body);
      font-size: 10px;
      letter-spacing: 3px;
      text-transform: uppercase;
      padding: 13px 24px;
      text-decoration: none;
      transition: background 0.2s;
    }
    .link-primary:hover { background: var(--gold-lt); }
    .link-secondary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 1px solid #1a3d2e;
      color: #4a6555;
      font-family: var(--font-body);
      font-size: 10px;
      letter-spacing: 3px;
      text-transform: uppercase;
      padding: 13px 24px;
      text-decoration: none;
      transition: border-color 0.2s, color 0.2s;
    }
    .link-secondary:hover { border-color: var(--gold-dk); color: var(--gold-dk); }

    /* Tech stack pills */
    .tech-stack {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-bottom: 24px;
    }
    .tech-pill {
      font-size: 9px;
      letter-spacing: 2px;
      text-transform: uppercase;
      background: #0d2b1f;
      color: #245c42;
      padding: 4px 10px;
      border: 1px solid #1a3d2e;
    }

    /* Results strip */
    .results-strip {
      background: var(--forest);
      border-top: 1px solid #1a3d2e;
      border-bottom: 1px solid #1a3d2e;
      padding: 80px 48px;
    }
    .results-inner {
      max-width: 1400px;
      margin: 0 auto;
    }
    .results-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      border-top: 1px solid #1a3d2e;
      padding-top: 40px;
      margin-top: 48px;
    }
    .result-item {
      padding-right: 32px;
      border-right: 1px solid #1a3d2e;
    }
    .result-item:last-child { border-right: none; padding-right: 0; padding-left: 32px; }
    .result-item:nth-child(2), .result-item:nth-child(3) { padding: 0 32px; }
    .result-num {
      font-family: var(--font-display);
      font-size: 68px;
      color: var(--gold);
      line-height: 1;
    }
    .result-label {
      font-size: 10px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #245c42;
      margin-top: 6px;
    }

    /* Responsive */
    @media (max-width: 900px) {
      .project-card { grid-template-columns: 1fr; direction: ltr; }
      .project-card.reverse { direction: ltr; }
      .project-preview { min-height: 280px; }
      .project-info { border-left: none !important; border-right: none !important; border-top: 1px solid #1a3d2e; padding: 36px 28px; }
      .projects-section { padding: 40px 24px 80px; }
      .results-grid { grid-template-columns: 1fr 1fr; gap: 2px; }
      .result-item { padding: 20px !important; border-right: none; border: 1px solid #1a3d2e; }
    }
  </style>
</head>
