<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Our Work — BrandForge Digital Agency</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:ital,wght@0,300;0,400;1,300&family=Playfair+Display:ital@1&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css" />
    <link rel="icon" href="/logo.png" type="image/x-icon">
</head>
<body>

  <nav id="nav">
    <a href="/" class="nav-logo">BrandForge</a>
    <div class="nav-links">
      <a href="/services">Services</a>
      <a href="/work">Work</a>
      <a href="/contact" class="nav-cta">Start a Project</a>
    </div>
  </nav>

  <section style="padding:160px 48px 80px;border-bottom:1px solid #222">
    <p class="section-label reveal">Selected Projects</p>
    <h1 class="section-title reveal" style="font-size:clamp(60px,10vw,130px)">
      Our <em>Work</em><br>Speaks.
    </h1>
  </section>

  <section style="padding:80px 48px 120px">
    <div class="work-page-grid">

      <div class="work-page-item reveal">
        <canvas class="work-page-canvas"></canvas>
        <div class="work-page-info">
          <div class="work-page-tag">E-Commerce · Shopify</div>
          <div class="work-page-name">LuxeHome Store</div>
        </div>
      </div>

      <div class="work-page-item reveal">
        <canvas class="work-page-canvas"></canvas>
        <div class="work-page-info">
          <div class="work-page-tag">Marketing · Meta Ads</div>
          <div class="work-page-name">FitLife Campaign</div>
        </div>
      </div>

      <div class="work-page-item reveal">
        <canvas class="work-page-canvas"></canvas>
        <div class="work-page-info">
          <div class="work-page-tag">Web Design · React</div>
          <div class="work-page-name">Apex SaaS Platform</div>
        </div>
      </div>

      <div class="work-page-item reveal">
        <canvas class="work-page-canvas"></canvas>
        <div class="work-page-info">
          <div class="work-page-tag">Branding · Full Identity</div>
          <div class="work-page-name">Noir Coffee Co.</div>
        </div>
      </div>

      <div class="work-page-item reveal">
        <canvas class="work-page-canvas"></canvas>
        <div class="work-page-info">
          <div class="work-page-tag">SEO · Content Strategy</div>
          <div class="work-page-name">Meridian Law Firm</div>
        </div>
      </div>

      <div class="work-page-item reveal">
        <canvas class="work-page-canvas"></canvas>
        <div class="work-page-info">
          <div class="work-page-tag">Web App · Next.js</div>
          <div class="work-page-name">TrackIQ Dashboard</div>
        </div>
      </div>

    </div>
  </section>

  <!-- RESULTS STRIP -->
  <section style="background:var(--white);color:var(--black);padding:80px 48px">
    <div style="max-width:1400px;margin:0 auto">
      <p class="section-label reveal" style="color:#666">Real Numbers</p>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:2px;margin-top:48px;border-top:1px solid #ddd;padding-top:40px">
        <div class="reveal">
          <div style="font-family:var(--font-display);font-size:72px;color:var(--black);line-height:1">340%</div>
          <div style="font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#666;margin-top:6px">Avg. Traffic Increase</div>
        </div>
        <div class="reveal">
          <div style="font-family:var(--font-display);font-size:72px;color:var(--black);line-height:1">$4.2M</div>
          <div style="font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#666;margin-top:6px">Revenue Generated</div>
        </div>
        <div class="reveal">
          <div style="font-family:var(--font-display);font-size:72px;color:var(--black);line-height:1">120+</div>
          <div style="font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#666;margin-top:6px">Completed Projects</div>
        </div>
        <div class="reveal">
          <div style="font-family:var(--font-display);font-size:72px;color:var(--black);line-height:1">2.8×</div>
          <div style="font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#666;margin-top:6px">Average ROAS</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="cta">
    <canvas id="cta-canvas"></canvas>
    <div class="cta-content">
      <h2 class="cta-title reveal">
        YOUR PROJECT
        <em>next.</em>
      </h2>
      <a href="/contact" class="btn-primary reveal">Start Today</a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="footer-top">
      <div class="footer-mark">BrandForge</div>
      <div class="footer-tagline">We build what others only imagine.</div>
    </div>
    <div class="footer-bottom">
      <span class="footer-copy">© 2025 BrandForge Studio. All rights reserved.</span>
      <div class="footer-links">
        <a href="/services">Services</a>
        <a href="/work">Work</a>
        <a href="/contact">Contact</a>
      </div>
    </div>
  </footer>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>