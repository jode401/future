<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dashboard — BrandForge</title>
  <link rel="icon" href="/logo.png" type="image/x-icon">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:ital,wght@0,300;0,400;1,300&family=Playfair+Display:ital@1&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --black:#000;--white:#fff;--off:#f0efeb;
      --bg:#080808;--s1:#111;--s2:#161616;
      --border:#1f1f1f;--dim:#555;--dim2:#888;
      --green:#1aff8c;--red:#ff3b3b;--amber:#ffcc00;
      --Fd:'Bebas Neue',sans-serif;
      --Fb:'DM Mono',monospace;
      --Fi:'Playfair Display',serif;
      --sw:220px;
    }
    html,body{height:100%;overflow:hidden}
    body{background:var(--bg);color:var(--white);font-family:var(--Fb);font-size:13px;cursor:none;display:flex}
    a{color:inherit;text-decoration:none}
    #cur{position:fixed;width:8px;height:8px;background:var(--white);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .25s,height .25s;mix-blend-mode:difference;}
    #cur.big{width:36px;height:36px}

    /* SIDEBAR */
    .sb{
      width:var(--sw);min-width:var(--sw);
      background:var(--black);border-right:1px solid var(--border);
      display:flex;flex-direction:column;height:100vh;
      position:fixed;top:0;left:0;z-index:50;
    }
    .sb-head{padding:28px 24px 20px;border-bottom:1px solid var(--border)}
    .sb-logo{font-family:var(--Fd);font-size:24px;letter-spacing:4px;display:block;margin-bottom:2px}
    .sb-sub{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--dim)}
    .sb-user{
      padding:16px 24px;border-bottom:1px solid var(--border);
      display:flex;align-items:center;gap:12px;
    }
    .av{
      width:32px;height:32px;background:var(--white);color:var(--black);
      font-size:10px;font-weight:bold;display:flex;align-items:center;justify-content:center;flex-shrink:0;
    }
    .av-name{font-size:11px;letter-spacing:.5px}
    .av-role{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--dim);margin-top:2px}
    .sb-nav{flex:1;padding:12px 0;overflow-y:auto}
    .sb-nav a{
      display:flex;align-items:center;gap:12px;
      padding:11px 24px;font-size:10px;letter-spacing:3px;text-transform:uppercase;
      color:var(--dim2);border-left:2px solid transparent;
      transition:color .2s,border-color .2s,background .2s;
    }
    .sb-nav a:hover{color:var(--white);background:var(--s1)}
    .sb-nav a.on{color:var(--white);border-left-color:var(--white);background:var(--s1)}
    .sb-nav svg{width:13px;height:13px;opacity:.5;flex-shrink:0}
    .sb-nav a.on svg,.sb-nav a:hover svg{opacity:1}
    .sb-foot{padding:18px 24px;border-top:1px solid var(--border)}
    .sb-logout{
      display:flex;align-items:center;gap:10px;
      font-size:10px;letter-spacing:3px;text-transform:uppercase;
      color:var(--dim);transition:color .2s;
    }
    .sb-logout:hover{color:var(--red)}

    /* MAIN */
    .main{margin-left:var(--sw);flex:1;display:flex;flex-direction:column;height:100vh;overflow:hidden}
    .topbar{
      height:58px;border-bottom:1px solid var(--border);
      display:flex;align-items:center;justify-content:space-between;
      padding:0 36px;flex-shrink:0;
      background:rgba(8,8,8,.92);backdrop-filter:blur(14px);
    }
    .tb-title{font-family:var(--Fd);font-size:20px;letter-spacing:3px}
    .tb-right{display:flex;align-items:center;gap:20px}
    .tb-time{font-size:10px;letter-spacing:3px;color:var(--dim)}
    .tb-back{
      font-size:10px;letter-spacing:3px;text-transform:uppercase;
      color:var(--dim);border:1px solid var(--border);
      padding:7px 16px;transition:color .2s,border-color .2s;
    }
    .tb-back:hover{color:var(--white);border-color:#444}
    .scroll{flex:1;overflow-y:auto;padding:32px 36px}

    /* HEADER */
    .pg-head{margin-bottom:28px}
    .pg-eyebrow{font-size:10px;letter-spacing:5px;text-transform:uppercase;color:var(--dim);margin-bottom:8px}
    .pg-title{font-family:var(--Fd);font-size:36px;letter-spacing:2px;margin-bottom:4px}
    .pg-sub{font-size:11px;color:var(--dim);letter-spacing:1px}

    /* GRID */
    .grid{
      display:grid;
      grid-template-columns:repeat(auto-fill,minmax(300px,1fr));
      gap:2px;
      margin-bottom:2px;
    }

    /* ENTRY CARD */
    .card{
      background:var(--s1);border:1px solid var(--border);
      padding:28px;position:relative;overflow:hidden;
      transition:background .2s;
    }
    .card:hover{background:var(--s2)}
    .card::after{
      content:'';position:absolute;bottom:0;left:0;right:0;
      height:2px;background:var(--white);
      transform:scaleX(0);transform-origin:left;
      transition:transform .4s;
    }
    .card:hover::after{transform:scaleX(1)}
    .card-top{
      display:flex;justify-content:space-between;
      align-items:flex-start;margin-bottom:20px;
    }
    .c-name{
      font-family:var(--Fd);font-size:24px;
      letter-spacing:1px;line-height:1;
    }
    .c-budget{
      font-family:var(--Fd);font-size:22px;
      color:var(--white);
    }
    .c-budget-label{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--dim);margin-top:2px;text-align:right}
    .field{margin-bottom:14px}
    .field:last-child{margin-bottom:0}
    .fl{font-size:9px;letter-spacing:4px;text-transform:uppercase;color:var(--dim);margin-bottom:4px}
    .fv{font-size:12px;color:var(--dim2);line-height:1.6;word-break:break-word}
    .card:hover .fv{color:var(--white)}
    .c-idx{
      position:absolute;top:20px;right:20px;
      font-family:var(--Fd);font-size:64px;
      color:var(--border);line-height:1;user-select:none;
    }

    /* EMPTY */
    .empty{
      border:1px solid var(--border);padding:80px 40px;
      text-align:center;
    }
    .empty-num{font-family:var(--Fd);font-size:80px;color:var(--border);line-height:1;margin-bottom:16px}
    .empty h2{font-family:var(--Fd);font-size:28px;letter-spacing:2px;margin-bottom:8px}
    .empty p{font-size:11px;color:var(--dim);letter-spacing:2px;text-transform:uppercase}

    @keyframes fu{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
    .card{animation:fu .5s both}
    <% if(typeof data !== 'undefined' && data) { %>
    <% for(let i=0;i<data.length;i++){ %>.card:nth-child(<%=i+1%>){animation-delay:<%=i*.06%>s}<% } %>
    <% } %>

    @media(max-width:820px){
      .sb{display:none}
      .main{margin-left:0}
      .scroll{padding:20px}
      .topbar{padding:0 20px}
    }
  </style>
</head>
<body>
<div id="cur"></div>

<!-- SIDEBAR -->
<aside class="sb">
  <div class="sb-head">
    <a href="/" class="sb-logo">BrandForge</a>
    <p class="sb-sub">Studio Dashboard</p>
  </div>
  <% if(typeof user !== 'undefined' && user){ %>
  <div class="sb-user">

    <div>
      <div class="av-name"><%=user.name%></div>
    </div>
  </div>
  <% } %>
  <nav class="sb-nav">
    <a href="/dashboard" class="on">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      Overview
    </a>
    <a href="/services">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
      Services
    </a>
    <a href="/work">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
      Portfolio
    </a>
    <a href="/contact">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
      Inquiries
    </a>
  </nav>
  <div class="sb-foot">
    <a href="/logout" class="sb-logout">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      Logout
    </a>
  </div>
</aside>

<!-- MAIN -->
<div class="main">
  <div class="topbar">
    <div class="tb-title">SUBMISSIONS</div>
    <div class="tb-right">
      <span class="tb-time" id="clock"></span>
      <a href="/" class="tb-back">&#8592; Site</a>
    </div>
  </div>

  <div class="scroll">
    <div class="pg-head">
      <p class="pg-eyebrow">Client Inquiries</p>
      <h1 class="pg-title">All Submissions</h1>
      <p class="pg-sub">
        <% if(typeof data !== 'undefined' && data && data.length > 0){ %>
          <%=data.length%> entr<%= data.length===1?'y':'ies'%> found
        <% } else { %>
          No submissions yet
        <% } %>
      </p>
    </div>

    <% if(typeof data !== 'undefined' && data && data.length > 0){ %>
    <div class="grid">
      <% data.forEach(function(item, i){ %>
      <div class="card">
        <div class="c-idx"><%=(i+1).toString().padStart(2,'0')%></div>
        <div class="card-top">
          <div class="c-name"><%=item.name%></div>
          <div>
            <div class="c-budget">$<%=item.budget%></div>
            <div class="c-budget-label">Budget</div>
          </div>
        </div>
        <div class="field">
          <div class="fl">Company</div>
          <div class="fv"><%=item.company%></div>
        </div>
        <div class="field">
          <div class="fl">Service</div>
          <div class="fv"><%=item.service%></div>
        </div>
        <div class="field">
          <div class="fl">Email</div>
          <div class="fv"><%=item.email%></div>
        </div>
        <div class="field">
          <div class="fl">Message</div>
          <div class="fv"><%=item.message%></div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } else { %>
    <div class="empty">
      <div class="empty-num">00</div>
      <h2>NO DATA YET</h2>
      <p>No submitted entries to display</p>
    </div>
    <% } %>
  </div>
</div>

<script>
const cur=document.getElementById('cur');
document.addEventListener('mousemove',e=>{cur.style.left=e.clientX+'px';cur.style.top=e.clientY+'px'});
document.querySelectorAll('a,.card').forEach(el=>{
  el.addEventListener('mouseenter',()=>cur.classList.add('big'));
  el.addEventListener('mouseleave',()=>cur.classList.remove('big'));
});
function tick(){
  const now=new Date();
  document.getElementById('clock').textContent=
    now.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:false});
}
tick();setInterval(tick,1000);
</script>
</body>
</html>