<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Services — VRTX Digital Agency</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:ital,wght@0,300;0,400;1,300&family=Playfair+Display:ital@1&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>

  <nav id="nav">
    <a href="/" class="nav-logo">VRTX</a>
    <div class="nav-links">
      <a href="/services">Services</a>
      <a href="/work">Work</a>
      <a href="/contact" class="nav-cta">Start a Project</a>
    </div>
  </nav>

  <!-- HERO -->
  <div class="services-page-hero">
    <canvas id="services-page-canvas"></canvas>
    <div class="services-page-hero-content">
      <p class="section-label">What We Offer</p>
      <h1 class="section-title" style="font-size:clamp(60px,10vw,140px)">
        Services<br>That <em>Scale</em>.
      </h1>
    </div>
  </div>

  <!-- SERVICES LIST -->
  <section style="padding:80px 48px 120px">
    <div class="services-list">

      <div class="service-row reveal">
        <div class="service-row-num">01</div>
        <div class="service-row-name">Web Design &amp; Development</div>
        <div class="service-row-desc">
          Fully custom websites — not templates. We design every pixel with intent, then build
          on modern stacks (React, Next.js, Node, Webflow) optimized for speed, SEO, and conversions.
          From a sleek landing page to a full SaaS platform.
        </div>
        <div class="service-row-price">From $1,200</div>
      </div>

      <div class="service-row reveal">
        <div class="service-row-num">02</div>
        <div class="service-row-name">E-Commerce Solutions</div>
        <div class="service-row-desc">
          Shopify, WooCommerce, or custom-built stores designed to sell. Product page optimization,
          checkout flow improvements, upsell systems, and ongoing A/B testing to maximize revenue per visitor.
        </div>
        <div class="service-row-price">From $1,800</div>
      </div>

      <div class="service-row reveal">
        <div class="service-row-num">03</div>
        <div class="service-row-name">Search Engine Optimization</div>
        <div class="service-row-desc">
          Technical SEO audits, keyword strategy, content optimization, and link building — built into
          a long-term growth engine. We don't chase shortcuts; we build rankings that last.
        </div>
        <div class="service-row-price">From $600/mo</div>
      </div>

      <div class="service-row reveal">
        <div class="service-row-num">04</div>
        <div class="service-row-name">Paid Advertising</div>
        <div class="service-row-desc">
          Google Ads, Meta Ads, TikTok — managed and optimized by humans, not bots. Full funnel
          creative, audience targeting, budget pacing, and ROAS reporting with zero fluff.
        </div>
        <div class="service-row-price">From $500/mo</div>
      </div>

      <div class="service-row reveal">
        <div class="service-row-num">05</div>
        <div class="service-row-name">Brand Identity Design</div>
        <div class="service-row-desc">
          Logo, color system, typography, brand guidelines, and visual language — everything a business
          needs to show up consistently and confidently across every touchpoint.
        </div>
        <div class="service-row-price">From $900</div>
      </div>

      <div class="service-row reveal">
        <div class="service-row-num">06</div>
        <div class="service-row-name">Social Media Management</div>
        <div class="service-row-desc">
          Strategy, content creation, scheduling, and analytics for Instagram, LinkedIn, TikTok, and X.
          We build audiences organically and convert followers into customers.
        </div>
        <div class="service-row-price">From $400/mo</div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section id="cta">
    <canvas id="cta-canvas"></canvas>
    <div class="cta-content">
      <h2 class="cta-title reveal">
        NOT SURE<br>WHERE TO
        <em>start?</em>
      </h2>
      <a href="/contact" class="btn-primary reveal">Book a Free Consultation</a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="footer-top">
      <div class="footer-mark">VRTX</div>
      <div class="footer-tagline">We build what others only imagine.</div>
    </div>
    <div class="footer-bottom">
      <span class="footer-copy">© 2025 VRTX Studio. All rights reserved.</span>
      <div class="footer-links">
        <a href="/services">Services</a>
        <a href="/work">Work</a>
        <a href="/contact">Contact</a>
      </div>
    </div>
  </footer>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>