<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Services — BrandForge</title>
  <meta name="description" content="Full-service digital solutions: web design, branding, social media, and complete digital packages." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css" />
  <link rel="icon" href="/logo.png" type="image/x-icon">
</head>
<body>
  <div class="noise-overlay"></div>

  <nav id="nav">
    <a href="/" class="nav-logo">BrandForge</a>
    <div class="nav-links">
      <a href="/services">Services</a>
      <a href="/work">Work</a>
      <a href="/contact" class="nav-cta">Start a Project</a>
    </div>
    <button class="nav-burger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </nav>
  <div class="mobile-nav">
    <a href="/">Home</a>
    <a href="/services">Services</a>
    <a href="/work">Work</a>
    <a href="/contact">Contact</a>
  </div>

  <!-- HERO -->
  <div class="services-page-hero">
    <canvas id="services-page-canvas"></canvas>
    <div class="services-page-hero-content">
      <p class="section-label">What We Offer</p>
      <h1 class="section-title" style="font-size:clamp(48px,8vw,96px)">
        Services that scale.
      </h1>
    </div>
  </div>

  <!-- SERVICES LIST -->
  <section style="padding:80px 56px 120px;max-width:1060px;margin:0 auto">
    <div class="services-list">
      <div class="service-row reveal">
        <div class="service-row-num">01</div>
        <div class="service-row-name">Web Design &amp; Development</div>
        <div class="service-row-desc">Fully custom websites — not templates. Optimized for speed, SEO, and conversions.</div>
        <div class="service-row-price">From $500</div>
      </div>
      <div class="service-row reveal">
        <div class="service-row-num">02</div>
        <div class="service-row-name">Brand Identity Design</div>
        <div class="service-row-desc">Logo suites, color systems, typography, and comprehensive brand guidelines.</div>
        <div class="service-row-price">From $200</div>
      </div>
      <div class="service-row reveal">
        <div class="service-row-num">03</div>
        <div class="service-row-name">Social Media Management</div>
        <div class="service-row-desc">Content creation, scheduling, and community engagement across all platforms.</div>
        <div class="service-row-price">From $300/mo</div>
      </div>
      <div class="service-row reveal" style="border-left:2px solid var(--blue);padding-left:20px">
        <div class="service-row-num">04</div>
        <div class="service-row-name"><strong>Pack BrandForge</strong></div>
        <div class="service-row-desc">Full brand identity, custom website, and ongoing social media management.</div>
        <div class="service-row-price"><strong>From $500/mo</strong></div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="cta">
    <canvas id="cta-canvas"></canvas>
    <div class="cta-content">
      <h2 class="cta-title reveal">Not sure where to start? <em>We'll guide you.</em></h2>
      <div class="reveal" style="display:flex;flex-direction:column;align-items:center;gap:10px">
        <a href="/contact" class="btn-primary" style="min-height:52px;display:inline-flex;align-items:center;padding:0 36px;font-size:18px">Book a Free Consultation</a>
        <small style="font-size:12px;color:rgba(255,255,255,0.3)">Free &nbsp;·&nbsp; No commitment &nbsp;·&nbsp; Response in 24h</small>
      </div>
    </div>
  </section>

  <footer>
    <div class="footer-top">
      <div class="footer-mark">BrandForge</div>
      <div class="footer-tagline">We build what others only imagine.</div>
    </div>
    <div class="footer-bottom">
      <span class="footer-copy">© 2025 BrandForge Studio. All rights reserved.</span>
      <div class="footer-links">
        <a href="/services">Services</a>
        <a href="/work">Work</a>
        <a href="/contact">Contact</a>
      </div>
    </div>
  </footer>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>