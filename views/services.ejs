<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Services — BrandForge Digital Agency</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:ital,wght@0,300;0,400;1,300&family=Playfair+Display:ital@1&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css" />
    <link rel="icon" href="/logo.png" type="image/x-icon">
</head>
<body>

  <nav id="nav">
    <a href="/" class="nav-logo">BrandForge</a>
    <div class="nav-links">
      <a href="/services">Services</a>
      <a href="/work">Work</a>
      <a href="/contact" class="nav-cta">Start a Project</a>
    </div>
  </nav>

  <!-- HERO -->
  <div class="services-page-hero">
    <canvas id="services-page-canvas"></canvas>
    <div class="services-page-hero-content">
      <p class="section-label">What We Offer</p>
      <h1 class="section-title" style="font-size:clamp(60px,10vw,140px)">
        Services<br>That <em>Scale</em>.
      </h1>
    </div>
  </div>

  <!-- SERVICES LIST -->
<section style="padding:80px 48px 120px; max-width: 1200px; margin: 0 auto;">
  <div class="services-list">

    <div class="service-row reveal">
      <div class="service-row-num">01</div>
      <div class="service-row-name">Web Design &amp; Development</div>
      <div class="service-row-desc">
        Fully custom websites — not templates. We design every pixel with intent, then build
        on modern stacks (EJS, Node.js, Webflow) optimized for speed, SEO, and conversions.
        From sleek landing pages to scalable SaaS platforms.
      </div>
      <div class="service-row-price">From $500</div>
    </div>

    <div class="service-row reveal">
      <div class="service-row-num">02</div>
      <div class="service-row-name">Brand Identity Design</div>
      <div class="service-row-desc">
        Logo suites, color systems, typography, and comprehensive brand guidelines. We build 
        the visual language your business needs to show up consistently and confidently 
        across every customer touchpoint.
      </div>
      <div class="service-row-price">From $200</div>
    </div>

    <div class="service-row reveal">
      <div class="service-row-num">03</div>
      <div class="service-row-name">Social Media Management</div>
      <div class="service-row-desc">
        End-to-end strategy: content creation, scheduling, and community engagement for 
        Instagram, LinkedIn, TikTok, and X. We grow organic audiences and transform 
        passive followers into loyal customers.
      </div>
      <div class="service-row-price">From $300/mo</div>
    </div>

    <div class="service-row reveal" style="border-left: 4px solid #000; padding-left: 20px;">
      <div class="service-row-num">04</div>
      <div class="service-row-name"><strong>Pack BrandForge</strong></div>
      <div class="service-row-desc">
        The ultimate growth engine. This all-in-one partner package includes full brand 
        identity development, a custom high-performance website, and ongoing monthly 
        social media management. Total brand cohesion for maximum impact.
      </div>
      <div class="service-row-price"><strong>From $500/mo</strong></div>
    </div>

  </div>
</section>

  <!-- CTA -->
  <section id="cta">
    <canvas id="cta-canvas"></canvas>
    <div class="cta-content">
      <h2 class="cta-title reveal">
        NOT SURE<br>WHERE TO
        <em>start?</em>
      </h2>
      <a href="/contact" class="btn-primary reveal">Book a Free Consultation</a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="footer-top">
      <div class="footer-mark">BrandForge</div>
      <div class="footer-tagline">We build what others only imagine.</div>
    </div>
    <div class="footer-bottom">
      <span class="footer-copy">© 2025 BrandForge Studio. All rights reserved.</span>
      <div class="footer-links">
        <a href="/services">Services</a>
              <a href="/work">Work</a>
        <a href="/contact">Contact</a>
      </div>
    </div>
  </footer>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>